{
  "name": "redline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time collaborative document review tool (portfolio/learning project)",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@node-rs/argon2": "^2.0.0",
    "arctic": "^3.0.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
