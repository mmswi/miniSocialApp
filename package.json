{
  "name": "redline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time collaborative document review tool (portfolio/learning project)",
  "scripts": {
    "api": "PORT=3001 APP_URL=http://localhost:3000 bun run --watch src/server.ts",
    "api:start": "bun run src/server.ts",
    "worker": "bun run --watch src/worker.ts",
    "worker:start": "bun run src/worker.ts",
    "api:test": "bun test \"$PWD/src/\"",
    "api:typecheck": "tsc --noEmit",
    "api:lint": "biome check src test",
    "api:format": "biome format --write src test",
    "api:db:generate": "drizzle-kit generate",
    "api:db:migrate": "drizzle-kit migrate",
    "api:db:studio": "drizzle-kit studio",
    "web": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:test": "cd web && bun run test",
    "web:typecheck": "cd web && bun run typecheck",
    "web:lint": "biome check web/src",
    "web:format": "biome format --write web/src"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@node-rs/argon2": "^2.0.0",
    "arctic": "^3.0.0",
    "bullmq": "^5.79.1",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
