# Server
PORT=3000
NODE_ENV=development
# Set to your proxy/load-balancer address or CIDR block — Classless Inter-Domain Routing, an IP
# range like 10.0.0.0/8 — in production so req.ip is the real client IP (per-IP rate limiting
# depends on it). Leave empty in dev. Do NOT set a value that blindly trusts X-Forwarded-For from
# any client — that lets attackers spoof a fresh IP per request.
TRUST_PROXY=
# Used to sign session cookies; generate a long random value for real use.
COOKIE_SECRET=dev-only-change-me-to-a-long-random-secret

# Postgres (matches docker-compose.yml; host port 5435 to avoid local conflicts)
DATABASE_URL=postgres://redline:redline@localhost:5435/redline

# Redis (session cache + later: queue/pub-sub; host port 6381 to avoid local conflicts)
REDIS_URL=redis://localhost:6381

# Google OAuth (create credentials in Google Cloud console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Email
EMAIL_FROM=noreply@localhost
APP_URL=http://localhost:3000
# SMTP transport. Defaults target the local Mailpit container (docker-compose) — read/click the mail at
# http://localhost:8025. In production point these at a real provider (Resend/SES): set SMTP_HOST, set
# SMTP_SECURE=true (port 465), and provide SMTP_USER/SMTP_PASS. SMTP_SECURE must be exactly 'true'/'false'.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
